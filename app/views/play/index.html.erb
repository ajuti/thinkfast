<!DOCTYPE html>
<html>
  <head>
    <title>Time to think fast</title>
    <%= stylesheet_link_tag "play", media: "all" %>
  </head>

  <body>
    <div class="play-page">
      <div class="bg-blue-300 flex w-full justify-center">
        <div class="flex">
          <%= button_to "Refresh Shop", refresh_path, method: :post, class: "flex-none w-16 border-2 border-indigo-500/100 h-20" %>
          <%= button_to "Shopslot 1", slot1_path, method: :post, class: "flex-1 border-2 border-indigo-500/100 h-20"%>
          <%= button_to "Shopslot 2", slot2_path, method: :post, class: "flex-1 border-2 border-indigo-500/100 h-20"%>
          <%= button_to "Shopslot 3", slot3_path, method: :post, class: "flex-1 border-2 border-indigo-500/100 h-20"%>
          <%= button_to "Shopslot 4", slot4_path, method: :post, class: "flex-1 border-2 border-indigo-500/100 h-20" %>
          <%= button_to "Shopslot 5", slot5_path, method: :post, class: "flex-1 border-2 border-indigo-500/100 h-20" %>
        </div>
      </div>
    </div>
  </body>
</html>